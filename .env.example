TOKEN=your_discord_bot_token
DATABASE_URL=postgresql://discord_bot:change_me@127.0.0.1:5432/discord_bot
DB_SSL=false

# Local laptop defaults keep idle resource use low.
HOSTING_PROFILE=laptop
DB_POOL_MAX=3
DB_IDLE_TIMEOUT_MS=10000
DB_CONNECTION_TIMEOUT_MS=10000
LOG_LEVEL=info

# Required for slash command registration.
CLIENT_ID=your_discord_application_id
GUILD_ID=1495760274827903086

# Existing bot behavior preserved from the original single-file bot.
ROLE_PANEL_CHANNEL_ID=1495760275448528928
ROLE_PANEL_MESSAGE_ID=
WELCOME_CHANNEL_ID=1495760275448528928
SITE_URL=https://tanksletloose.carrd.co/
GENERAL_CHANNEL_URL=https://discord.com/channels/1495760274827903086/1495924550662098944
GAME_CHANNEL_ID=1447381195003400340
READY_ROLE_ID=1496201325317197895

# Optional JSON override. Defaults preserve the existing role IDs.
# ROLE_MAP_JSON={"role_beginner":"1496208141753253888","role_medium":"1496208188775727286","role_expert":"1496208236502585588"}

# Leveling behavior.
TEXT_XP_COOLDOWN_SECONDS=15
VOICE_XP_SECONDS_PER_POINT=120
VOICE_TRACKING_INTERVAL_MS=120000
MAX_LEVEL=500

# Comma-separated channel IDs that should never award voice XP.
AFK_VOICE_CHANNEL_IDS=

# Gallery feature. These are used as DB-backed defaults when a guild is initialized.
GALLERY_SHOWCASE_CHANNEL_ID=
GALLERY_MEME_CHANNEL_ID=
GALLERY_LOG_CHANNEL_ID=
GALLERY_SUBMISSION_COOLDOWN_HOURS=6
GALLERY_MAX_SUBMISSIONS_PER_24H=3
